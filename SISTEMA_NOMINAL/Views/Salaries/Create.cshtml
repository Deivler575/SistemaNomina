@{
    Layout = "_Layout";
}
@model SistemaNomina.Models.Salary

<h2>Agregar Salario</h2>

<form asp-action="Create" method="post">
    <div>
        <label asp-for="EmpNo"></label>
        <input asp-for="EmpNo" />
        <span asp-validation-for="EmpNo"></span>
    </div>
    <div>
        <label asp-for="SalaryAmount"></label>
        <input asp-for="SalaryAmount" />
        <span asp-validation-for="SalaryAmount"></span>
    </div>
    <div>
        <label asp-for="FromDate"></label>
        <input asp-for="FromDate" type="date" />
        <span asp-validation-for="FromDate"></span>
    </div>
    <div>
        <label asp-for="ToDate"></label>
        <input asp-for="ToDate" type="date" />
        <span asp-validation-for="ToDate"></span>
    </div>
    <button type="submit">Agregar</button>
</form>
