@{
    Layout = "_Layout";
}

@model SistemaNomina.Models.Employee

<h2>Agregar Empleado</h2>

<form asp-action="Create" method="post">
    <div>
        <label asp-for="CI"></label>
        <input asp-for="CI" />
        <span asp-validation-for="CI"></span>
    </div>
    <div>
        <label asp-for="BirthDate"></label>
        <input asp-for="BirthDate" type="date" />
        <span asp-validation-for="BirthDate"></span>
    </div>
    <div>
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" />
        <span asp-validation-for="FirstName"></span>
    </div>
    <div>
        <label asp-for="LastName"></label>
        <input asp-for="LastName" />
        <span asp-validation-for="LastName"></span>
    </div>
    <div>
        <label asp-for="Gender"></label>
        <select asp-for="Gender">
            <option value="M">Masculino</option>
            <option value="F">Femenino</option>
        </select>
        <span asp-validation-for="Gender"></span>
    </div>
    <div>
        <label asp-for="HireDate"></label>
        <input asp-for="HireDate" type="date" />
        <span asp-validation-for="HireDate"></span>
    </div>
    <div>
        <label asp-for="Correo"></label>
        <input asp-for="Correo" />
        <span asp-validation-for="Correo"></span>
    </div>
    <button type="submit">Agregar</button>
</form>

